# --- Security & Environment ---
# Critical: Never commit your secrets (API keys, DB passwords, JWT secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Python / Flask ---
__pycache__/
*.py[cod]
*$py.class
